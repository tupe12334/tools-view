{
  "name": "toolsview",
  "version": "1.0.0",
  "description": "Analyze Claude skill relationships and emit a graph JSON + HTML viewer",
  "type": "module",
  "bin": {
    "toolsview": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "local": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
